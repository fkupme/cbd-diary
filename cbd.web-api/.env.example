# Шаблон переменных окружения cbd.web-api.
# Локальная разработка: скопируй в .env (он в .gitignore и .dockerignore).
# Прод: значения, помеченные [secret], живут в GitHub Secrets — деплой
# (.github/workflows/deploy.yml) собирает из них .env на сервере.

NODE_ENV=development
PORT=3002
APP_API_PREFIX=api
APP_API_VERSION=v1
LOG_LEVEL=debug

# --- База данных ---
# [secret] POSTGRES_PASSWORD — отдельным секретом, DATABASE_URL собирается в compose
DATABASE_URL=postgresql://postgres:dev_password@localhost:5433/cbd_diary_dev?schema=public
POSTGRES_DB=cbd_diary_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password

# --- JWT --- [secret] оба
JWT_ACCESS_SECRET=dev_access_secret_key_123
JWT_REFRESH_SECRET=dev_refresh_secret_key_456
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- AI (Gemini) ---
# [secret] GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
# Бюджет «размышлений» 2.5-моделей; 0 — выключено (быстрые ответы чата)
GEMINI_THINKING_BUDGET=0

# --- Web / remote push (Firebase Cloud Messaging) ---
# [secret] FIREBASE_SERVICE_ACCOUNT — полный JSON service account ОДНОЙ строкой
# (Firebase Console -> Project settings -> Service accounts -> Generate new private key).
# Им firebase-admin шлёт пуши (Android/iOS/Web). Пусто — push выключен.
FIREBASE_SERVICE_ACCOUNT=

# --- Traefik (только прод) ---
API_DOMAIN=api.cbd-diary.ru
