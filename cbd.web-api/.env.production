# Шаблон прод-окружения. РЕАЛЬНЫЕ значения сюда не пишутся:
# секреты живут в GitHub Secrets, деплой собирает .env на сервере
# (.github/workflows/deploy.yml). Полный список переменных — .env.example.
NODE_ENV=production
PORT=3002
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/cbd_diary?schema=public
JWT_ACCESS_SECRET=change_me_in_prod
JWT_REFRESH_SECRET=change_me_in_prod
LOG_LEVEL=info
GEMINI_API_KEY=change_me_in_prod
GEMINI_MODEL=gemini-2.5-flash
CORS_ORIGIN=https://cbd-diary.ru
API_DOMAIN=api.cbd-diary.ru
