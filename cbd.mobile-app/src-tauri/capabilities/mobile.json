{
	"$schema": "../gen/schemas/mobile-schema.json",
	"identifier": "mobile",
	"description": "Mobile permissions for all platforms",
	"platforms": ["android", "iOS"],
	"windows": ["main"],
	"permissions": [
		"core:default",
		"notification:default",
		"sql:default",
		"opener:default",
		{
			"identifier": "http:default",
			"allow": [
				{ "url": "https://jsonplaceholder.typicode.com/*" },
				{ "url": "https://api.cbd-diary.com/*" },
				{ "url": "http://localhost:*" },
				{ "url": "http://127.0.0.1:*" },
				{ "url": "http://10.0.2.2:*" },
				{ "url": "http://host.docker.internal:*" },
				{ "url": "http://192.168.*:*" },
				{ "url": "http://10.*:*" },
				{ "url": "http://172.*:*" },
				{ "url": "https://*.typicode.com/*" }
			]
		},
		{
			"identifier": "sql:default",
			"allow": [
				{
					"database": "sqlite:cbd_diary.db"
				}
			]
		},
		"store:default",
		"store:allow-load",
		"store:allow-get",
		"store:allow-set",
		"store:allow-save",
		"store:allow-delete",
		"store:allow-clear",
		"store:allow-keys"
	]
}
