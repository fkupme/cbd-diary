{
	"name": "cbdmobile-app",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"start": ". \"$HOME/.cargo/env\" 2>/dev/null || true; export JAVA_HOME=\"/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home\"; export ANDROID_HOME=\"/usr/local/share/android-commandlinetools\"; export ANDROID_SDK_ROOT=\"$ANDROID_HOME\"; export PATH=\"$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$ANDROID_HOME/emulator:$PATH\"; export NDK_HOME=\"${NDK_HOME:-$ANDROID_HOME/ndk/27.3.13750724}\"; export VITE_API_BASE_URL=\"${VITE_API_BASE_URL:-http://localhost:3002/api/v1}\"; npm run start:containers && (adb reverse tcp:3002 tcp:3002 >/dev/null 2>&1 || true) && npm run android:dev",
		"start:containers": "cd .. && POSTGRES_HOST_PORT=${POSTGRES_HOST_PORT:-5433} docker compose --env-file .env.development up -d postgres redis api-dev",
		"dev": "vite",
		"dev:lan": "vite --host 0.0.0.0 --port 5173",
		"build": "vue-tsc --noEmit && vite build",
		"build:tauri": "vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"android:init": "tauri android init",
		"android:dev": "tauri android dev",
		"android:build": "tauri android build",
		"android:build:debug": "tauri android build --debug",
		"android:build:release": "tauri android build",
		"android:build:apk": "tauri android build --apk",
		"android:build:aab": "tauri android build --aab",
		"android:devices": "adb devices",
		"android:emulator": "emulator -list-avds",
		"android:studio": "tauri android dev --open",
		"ios:init": "tauri ios init",
		"ios:dev": "tauri ios dev",
		"ios:dev:sim": "concurrently \"npm:dev:lan\" \"tauri ios dev --open\"",
		"ios:dev:device": "concurrently \"npm:dev:lan\" \"tauri ios dev\"",
		"ios:build": "tauri ios build",
		"ios:build:debug": "tauri ios build --debug",
		"ios:build:release": "tauri ios build",
		"ios:build:ipa": "tauri ios build --ipa",
		"ios:build:app": "tauri ios build --app",
		"ios:sim:list": "xcrun simctl list devices",
		"ios:open:xcode": "tauri ios dev --open",
		"ios:clean": "git clean -fdX src-tauri/gen/ios || true"
	},
	"dependencies": {
		"@quasar/extras": "^1.17.0",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-biometric": "^2.2.2",
		"@tauri-apps/plugin-http": "^2.4.4",
		"@tauri-apps/plugin-notification": "^2.2.3",
		"@tauri-apps/plugin-opener": "^2",
		"@tauri-apps/plugin-sql": "^2.2.1",
		"@tauri-apps/plugin-store": "^2.2.1",
		"pinia": "^3.0.3",
		"quasar": "^2.18.1",
		"socket.io-client": "^4.8.1",
		"vue": "^3.5.13",
		"vue-i18n": "^9.14.4",
		"vue-router": "^4.5.1",
		"chart.js": "^4.4.3",
		"vue-chartjs": "^5.3.1"
	},
	"devDependencies": {
		"@quasar/vite-plugin": "^1.9.0",
		"@tauri-apps/cli": "^2",
		"@vitejs/plugin-vue": "^5.2.1",
		"concurrently": "^8.2.1",
		"sass": "^1.89.2",
		"typescript": "~5.6.2",
		"vite": "^6.0.3",
		"vue-tsc": "^2.1.10"
	}
}
