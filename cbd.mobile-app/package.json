	"scripts": {
		"dev": "vite",
		"dev:lan": "vite --host 0.0.0.0 --port 5173",
		"build": "vue-tsc --noEmit && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"android:init": "tauri android init",
		"android:dev": "tauri android dev",
		"android:build": "tauri android build",
		"android:build:debug": "tauri android build --debug",
		"android:build:release": "tauri android build",
		"android:build:apk": "tauri android build --apk",
		"android:build:aab": "tauri android build --aab",
