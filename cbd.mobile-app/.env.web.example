# Web/PWA-сборка (vite --mode web) читает .env.web.
# Скопируй в .env.web и заполни (в CI значения приходят из GitHub Secrets как env).
#
# Это ПУБЛИЧНЫЙ web-config Firebase — он и так уезжает в браузер, не секрет.
# Серверный секрет (service account) живёт ТОЛЬКО на бэке (FIREBASE_SERVICE_ACCOUNT).
#
# Firebase Console -> Project settings:
#   - вкладка General -> твоё Web app -> SDK setup and configuration (apiKey и пр.)
#   - вкладка Cloud Messaging -> Web Push certificates -> Key pair (VITE_FIREBASE_VAPID_KEY)

# Адрес API (если не задан — в dev берётся с того же хоста :3002)
# VITE_API_BASE_URL=https://api.cbd-diary.ru/api/v1

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
